# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Simulation mode (true = use simulated sensors, no Pi needed)
EDEN_SIMULATE=true

# AWS
AWS_REGION=us-west-2
DYNAMO_TABLE_PREFIX=eden

# Local LLM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Reconciler
RECONCILE_INTERVAL_SECONDS=30

# Logging
LOG_LEVEL=INFO

# Syngenta MCP Knowledge Base
SYNGENTA_MCP_GATEWAY_URL=https://kb-start-hack-gateway-buyjtibfpg.gateway.bedrock-agentcore.us-east-2.amazonaws.com/mcp
# SYNGENTA_MCP_AUTH_TOKEN=

# NASA MCP server (20+ NASA APIs via stdio subprocess)
NASA_API_KEY=your-nasa-api-key-here
NASA_MCP_COMMAND=npx
NASA_MCP_ARGS=-y,@programcomputer/nasa-mcp-server@latest

# AgentCore Gateway + Runtime (set after `make deploy-agentcore`)
# AGENTCORE_GATEWAY_ID=
# AGENTCORE_GATEWAY_ENDPOINT=
# AGENTCORE_RUNTIME_ENDPOINT=
